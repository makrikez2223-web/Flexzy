<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>🎮 SECRET GAMES</title>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Press+Start+2P&display=swap');
    
    * { margin: 0; padding: 0; box-sizing: border-box; }
    
    body {
      background: linear-gradient(135deg, #0a001f, #1a0033, #000000);
      color: #fff;
      font-family: 'Press Start 2P', cursive;
      text-align: center;
      min-height: 100vh;
      padding: 30px 20px;
    }

    h1 {
      font-size: 3.8rem;
      margin-bottom: 30px;
      text-shadow: 0 0 20px #ff00ff, 0 0 40px #ff00ff, 0 0 70px #00ffff;
      color: #ff00ff;
      animation: glow 2s infinite alternate;
    }

    @keyframes glow { from { text-shadow: 0 0 20px #ff00ff; } to { text-shadow: 0 0 50px #ff00ff, 0 0 80px #00ffff; } }

    .secret-btn {
      background: linear-gradient(#ff00ff, #aa00aa);
      color: white;
      border: 5px solid #fff;
      padding: 25px 80px;
      font-size: 2rem;
      cursor: pointer;
      border-radius: 20px;
      margin: 20px;
      display: inline-block;
      transition: all 0.4s;
      box-shadow: 0 0 40px #ff00ff;
      text-transform: uppercase;
    }
    .secret-btn:hover {
      transform: scale(1.1) rotate(3deg);
      background: linear-gradient(#00ffff, #00aaaa);
      color: #000;
      box-shadow: 0 0 60px #00ffff;
    }

    .proxy-input {
      width: 80%;
      max-width: 700px;
      padding: 18px;
      font-family: 'Press Start 2P', cursive;
      font-size: 1.1rem;
      margin: 20px auto;
      background: #110022;
      border: 4px solid #00ffff;
      color: #fff;
      border-radius: 12px;
    }

    .proxy-container, .games-grid, .game-container {
      display: none;
      max-width: 1250px;
      margin: 30px auto;
    }
    .active { display: block !important; }

    iframe {
      width: 100%;
      height: 680px;
      border: 7px solid #ffffff;
      border-radius: 18px;
      background: #000;
      box-shadow: 0 0 40px rgba(0, 255, 255, 0.6);
    }

    .buttons button {
      background: #ff00ff;
      color: white;
      border: none;
      padding: 15px 28px;
      margin: 8px;
      font-family: 'Press Start 2P', cursive;
      cursor: pointer;
      border-radius: 10px;
      transition: 0.3s;
    }
    .buttons button:hover {
      background: #00ffff;
      color: #000;
      transform: scale(1.06);
    }

    .fullscreen-btn { background: #00ff00; font-size: 1.35rem; padding: 20px 50px; }
    .proxy-select { padding: 12px; font-size: 1rem; background: #220044; color: #0ff; border: 3px solid #00ffff; margin: 10px; }

    .quick-links button {
      font-size: 0.95rem;
      padding: 12px 20px;
    }
  </style>
</head>
<body>
  <h1>🎮 SECRET GAMES</h1>

  <button class="secret-btn" onclick="showGames()">🔒 JUEGOS SECRETOS</button>
  <button class="secret-btn" onclick="showProxy()" style="background: linear-gradient(#00ccff, #0066aa);">🌐 NAVEGADOR PROXY</button>

  <!-- Menú de Juegos -->
  <div class="games-grid" id="gamesMenu">
    <div class="game-card" onclick="playGame('Slope', 'https://slope3unblocked.github.io/')"><h3>🚀 Slope</h3></div>
    <div class="game-card" onclick="playGame('Slope 2', 'https://slope2unblocked.github.io/')"><h3>🚀 Slope 2</h3></div>
    <div class="game-card" onclick="playGame('Tunnel Rush', 'https://tunnelrushunblocked.github.io/')"><h3>🌀 Tunnel Rush</h3></div>
    <div class="game-card" onclick="playGame('1v1 LOL', 'https://1v1lol-unblocked.bitbucket.io/')"><h3>⚔️ 1v1 LOL</h3></div>
    <div class="game-card" onclick="playGame('Geometry Dash', 'https://geometrydashunblocked.github.io/')"><h3>📐 Geometry Dash</h3></div>
    <div class="game-card" onclick="playGame('Retro Bowl', 'https://retrobowlunblocked.github.io/')"><h3>🏈 Retro Bowl</h3></div>
    <div class="game-card" onclick="playGame('Drive Mad', 'https://drivemadunblocked.github.io/')"><h3>🚗 Drive Mad</h3></div>
    <div class="game-card" onclick="playGame('Basket Bros', 'https://basketbros.io/')"><h3>🏀 Basket Bros</h3></div>
    <div class="game-card" onclick="playGame('Stickman Hook', 'https://stickman-hook.github.io/')"><h3>🪝 Stickman Hook</h3></div>
    <div class="game-card" onclick="playGame('Madalin Stunt Cars 2', 'https://madalinstuntcars2unblocked.github.io/')"><h3>🏎️ Madalin Stunt Cars 2</h3></div>
  </div>

  <!-- Área del Juego -->
  <div id="gameArea" class="game-container">
    <h2 id="gameTitle" style="color:#00ffff; margin-bottom:20px;"></h2>
    <iframe id="gameFrame" allowfullscreen></iframe>
    <div class="buttons">
      <button onclick="openInAboutBlank()" class="fullscreen-btn">🌐 PANTALLA COMPLETA</button>
      <button onclick="backToMenu()">← VOLVER AL MENÚ</button>
    </div>
  </div>

  <!-- Navegador Proxy Mejorado -->
  <div id="proxyArea" class="proxy-container">
    <h2 style="color:#00ffcc; margin:20px 0;">🌐 NAVEGADOR PROXY PRO</h2>
    
    <select id="proxyServer" class="proxy-select">
      <option value="https://www.croxyproxy.com/">CroxyProxy (Mejor para videos)</option>
      <option value="https://www.4everproxy.com/">4everProxy</option>
      <option value="https://www.proxysite.com/">ProxySite</option>
      <option value="https://blockaway.net/">BlockAway</option>
      <option value="https://proxyium.com/">Proxyium</option>
    </select>

    <input type="text" id="urlInput" class="proxy-input" placeholder="https://ejemplo.com" value="https://www.google.com">
    
    <div class="buttons">
      <button onclick="goToUrl()">🚀 IR A LA URL</button>
      <button onclick="reloadProxy()">↻ RECARGAR</button>
      <button onclick="backToMenu()">← VOLVER AL MENÚ</button>
    </div>

    <div class="quick-links" style="margin:20px 0;">
      <button onclick="quickProxy('https://youtube.com')">YouTube</button>
      <button onclick="quickProxy('https://google.com')">Google</button>
      <button onclick="quickProxy('https://discord.com')">Discord</button>
      <button onclick="quickProxy('https://roblox.com')">Roblox</button>
    </div>

    <iframe id="proxyFrame" allowfullscreen></iframe>
  </div>

  <script>
    let currentUrl = '';
    let currentTitle = '';

    function showGames() {
      hideAll();
      document.getElementById('gamesMenu').style.display = 'grid';
    }

    function showProxy() {
      hideAll();
      document.getElementById('proxyArea').classList.add('active');
      // Cargar proxy por defecto
      setTimeout(() => goToUrl(), 300);
    }

    function hideAll() {
      document.getElementById('gamesMenu').style.display = 'none';
      document.getElementById('gameArea').classList.remove('active');
      document.getElementById('proxyArea').classList.remove('active');
    }

    function playGame(title, url) {
      currentTitle = title;
      currentUrl = url;
      hideAll();
      document.getElementById('gameArea').classList.add('active');
      document.getElementById('gameTitle').textContent = title;
      document.getElementById('gameFrame').src = url;
    }

    function goToUrl() {
      const baseProxy = document.getElementById('proxyServer').value;
      let url = document.getElementById('urlInput').value.trim();
      
      if (!url) return alert("Introduce una URL válida");
      if (!url.startsWith('http')) url = 'https://' + url;

      const fullUrl = `${baseProxy}?url=${encodeURIComponent(url)}`;
      document.getElementById('proxyFrame').src = fullUrl;
    }

    function quickProxy(url) {
      document.getElementById('urlInput').value = url;
      goToUrl();
    }

    function reloadProxy() {
      const frame = document.getElementById('proxyFrame');
      frame.src = frame.src;
    }

    function openInAboutBlank() {
      if (!currentUrl) return;
      const win = window.open('about:blank', '_blank');
      if (win) {
        win.document.write(`
          <!DOCTYPE html><html><head><title>${currentTitle}</title>
          <style>body,html{margin:0;padding:0;height:100%;overflow:hidden;background:#000;}
          iframe{width:100%;height:100%;border:none;}</style></head>
          <body><iframe src="${currentUrl}" allowfullscreen></iframe></body></html>
        `);
        win.document.close();
      }
    }

    function backToMenu() {
      document.getElementById('gameFrame').src = '';
      document.getElementById('proxyFrame').src = '';
      hideAll();
      document.getElementById('gamesMenu').style.display = 'grid';
    }

    // Tecla Escape
    document.addEventListener('keydown', e => {
      if (e.key === "Escape") backToMenu();
    });
  </script>
</body>
</html>
